# Configuration d'environnement - NE PAS COMMITTER EN PRODUCTION
# Copier .env.example en .env et adapter les valeurs locales

# URL de base du site
BASE_URL=/Hebergement/maokaa/

# Base de données
DB_HOST=localhost
DB_NAME=maokaa
DB_USER=root
DB_PASS=

# Répertoires uploads
UPLOAD_DIR=assets/images/
BROCHURE_DIR=assets/brochures/

# Limites de fichiers (en bytes)
MAX_IMAGE_SIZE=2097152
MAX_PDF_SIZE=5242880
